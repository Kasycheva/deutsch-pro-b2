{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/vite",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/$1",
      "check": true
    }
  ]
}
